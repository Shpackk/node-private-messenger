{
	"compilerOptions": {
		"target": "ES2022",
		"module": "ESNext",
		"moduleResolution": "Bundler",
		"strict": true,
		"esModuleInterop": true,
		"skipLibCheck": true,
		"resolveJsonModule": true,
		"jsx": "react-jsx",
		"baseUrl": ".",
		"paths": {
			"@prototype/contracts": ["packages/contracts/src/index.ts"],
			"@prototype/domain": ["packages/domain/src/index.ts"],
			"@prototype/db": ["packages/db/src/index.ts"]
		}
	}
}
