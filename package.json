{
	"name": "private-messenger-backend",
	"private": true,
	"version": "0.1.0",
	"packageManager": "pnpm@11.6.0",
	"engines": {
		"node": ">=24.16.0 <25",
		"pnpm": "11.6.0"
	},
	"scripts": {
		"build": "pnpm -r build",
		"check": "pnpm lint && pnpm typecheck && pnpm test",
		"dev": "pnpm --filter @messenger/api dev",
		"lint": "biome check .",
		"lint:fix": "biome check --write .",
		"format:fix": "biome format --write .",
		"format": "biome format .",
		"typecheck": "pnpm --filter @messenger/contracts build && pnpm -r typecheck",
		"test": "vitest run",
		"test:watch": "vitest",
		"audit": "pnpm audit --audit-level high",
		"load:ws": "node scripts/load/websocket.mjs",
		"cdk": "pnpm --filter @messenger/infra cdk"
	},
	"devDependencies": {
		"@biomejs/biome": "1.9.4",
		"@types/node": "24.10.1",
		"tsx": "4.21.0",
		"typescript": "6.0.3",
		"vitest": "4.1.8"
	}
}
